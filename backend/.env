SECRET_KEY=...
# ↑ Never put this in code — if someone sees your GitHub
# they can forge sessions and tokens

MONGO_URI=mongodb://localhost:27017
# ↑ Local MongoDB for now
# Later replace with Atlas URI

MONGO_DB_NAME=fitai_db

REDIS_URL=redis://localhost:6379/0
# ↑ Redis running locally
# /0 means database 0 (Redis has 16 databases 0-15)

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# ↑ S3 credentials — leave empty for now
# We fill these in Phase 3 when we set up image storage